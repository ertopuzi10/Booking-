using MediatR;
using System;
using System.Linq;
using System.Security.Cryptography;
using System.Text;
using System.Threading;
using System.Threading.Tasks;
using Booking.Infrastructure.Persistence;
using Booking.Domain.Entities;
using Microsoft.EntityFrameworkCore;

namespace Booking.Application.Features.Users.Register
{
    public class RgisterUserCommandHandler : IRequestHandler<RegisterUserCommand, int>
    {
        private readonly BookingDbContext _context;

        public RgisterUserCommandHandler(BookingDbContext context)
        {
            _context = context;
        }

        public async Task<int> Handle(RegisterUserCommand request, CancellationToken cancellationToken)
        {
            if (string.IsNullOrWhiteSpace(request.Email))
                throw new ArgumentException("Email is required");
            if (string.IsNullOrWhiteSpace(request.Password))
                throw new ArgumentException("Password is required");

            // Check existing user
            var exists = await _context.Users.AnyAsync(u => u.Email == request.Email, cancellationToken);
            if (exists)
                throw new InvalidOperationException("Email already registered");

            // Ensure roles exist
            var userRole = await _context.Roles.FirstOrDefaultAsync(r => r.Name == "User", cancellationToken);
            if (userRole == null)
            {
                userRole = new Roles { Name = "User", Description = "Default user role", IsDefault = true };
                _context.Roles.Add(userRole);
            }

            var adminRole = await _context.Roles.FirstOrDefaultAsync(r => r.Name == "Admin", cancellationToken);
            if (adminRole == null)
            {
                adminRole = new Roles { Name = "Admin", Description = "Administrator role", IsDefault = false };
                _context.Roles.Add(adminRole);
            }

            // Hash password (SHA256)
            string Hash(string input)
            {
                using var sha = SHA256.Create();
                var bytes = Encoding.UTF8.GetBytes(input);
                var hash = sha.ComputeHash(bytes);
                return Convert.ToHexString(hash);
            }

            var user = new Users
            {
                FirstName = request.FirstName,
                LastName = request.LastName,
                Email = request.Email,
                Password = Hash(request.Password),
                IsActive = true,
                CreatedAt = DateTime.UtcNow,
                LastModifiedAt = DateTime.UtcNow
            };

            _context.Users.Add(user);

            // Save changes to get user.Id populated if needed
            await _context.SaveChangesAsync(cancellationToken);

            // Assign role
            var roleToAssign = request.IsAdmin ? adminRole : userRole;
            // roleToAssign may be detached/new; ensure we have the tracked entity
            var trackedRole = await _context.Roles.FirstOrDefaultAsync(r => r.Name == roleToAssign.Name, cancellationToken);
            if (trackedRole == null)
            {
                trackedRole = roleToAssign;
                _context.Roles.Add(trackedRole);
                await _context.SaveChangesAsync(cancellationToken);
            }

            var userRoleEntry = new UserRoles
            {
                UserId = user.Id,
                RoleId = trackedRole.Id,
                AssignedAt = DateTime.UtcNow
            };

            _context.UserRoles.Add(userRoleEntry);

            await _context.SaveChangesAsync(cancellationToken);

            return user.Id;
        }
    }
}
